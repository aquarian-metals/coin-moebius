{
	"name": "@aquarian-metals/coin-moebius-element",
	"version": "0.3.0",
	"description": "Drop-in <coin-moebius-buy> custom element — paste one script tag and one HTML element, get a working buy button with provider-picker modal. CSS-customizable via custom properties and ::part().",
	"keywords": [
		"payments",
		"web-components",
		"custom-element",
		"checkout",
		"coin-moebius"
	],
	"author": "aquarian-metals",
	"license": "MIT",
	"homepage": "https://github.com/aquarian-metals/coin-moebius#readme",
	"bugs": {
		"url": "https://github.com/aquarian-metals/coin-moebius/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aquarian-metals/coin-moebius.git",
		"directory": "packages/element"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"./dist/index.js"
	],
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./element-class": {
			"types": "./dist/element-class.d.ts",
			"import": "./dist/element-class.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
		"build": "npm run clean && tsc",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"typescript": "~5.8.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
