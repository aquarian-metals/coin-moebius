{
	"name": "@aquarian-metals/coin-moebius-manual",
	"version": "3.0.0",
	"description": "Manual / async payment provider for Coin Moebius — covers Goldbacks, cash in mail, wire transfer, personal check, barter, and any 'I'll confirm receipt by hand' payment method.",
	"keywords": [
		"payments",
		"manual",
		"goldbacks",
		"async",
		"coin-moebius"
	],
	"author": "aquarian-metals",
	"license": "MIT",
	"homepage": "https://github.com/aquarian-metals/coin-moebius#readme",
	"bugs": {
		"url": "https://github.com/aquarian-metals/coin-moebius/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aquarian-metals/coin-moebius.git",
		"directory": "packages/providers/manual"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
		"build": "tsc",
		"test": "vitest run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"engines": {
		"node": ">=18"
	},
	"peerDependencies": {
		"@aquarian-metals/coin-moebius-core": "^3.0.0"
	},
	"devDependencies": {
		"@aquarian-metals/coin-moebius-core": "^3.0.0",
		"typescript": "~5.8.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
