{
	"name": "@aquarianmetals/coin-moebius-monero-cryptomus",
	"version": "0.1.0-beta.1",
	"description": "Monero (via Cryptomus) provider for Coin Moebius — browser initiate entry plus a server-only webhook verifier under the ./server subpath.",
	"keywords": [
		"payments",
		"monero",
		"xmr",
		"cryptomus",
		"crypto",
		"webhook",
		"coin-moebius"
	],
	"author": "aquarian-metals",
	"license": "MIT",
	"homepage": "https://github.com/aquarian-metals/coin-moebius#readme",
	"bugs": {
		"url": "https://github.com/aquarian-metals/coin-moebius/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aquarian-metals/coin-moebius.git",
		"directory": "packages/providers/monero-cryptomus"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@aquarianmetals/coin-moebius-core": "^0.1.0-beta.1"
	},
	"devDependencies": {
		"typescript": "~5.8.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
