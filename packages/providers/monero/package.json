{
	"name": "@aquarian-metals/coin-moebius-monero",
	"version": "1.0.0",
	"description": "Self-hosted Monero provider for Coin Moebius — direct wallet-RPC integration. No third-party gateway, no custodial keys, no API tokens. The merchant runs monerod + monero-wallet-rpc and a small indexer; this package supplies the browser provider, the server-side creator (subaddress minting), the webhook verifier, and the indexer factory.",
	"keywords": [
		"payments",
		"monero",
		"xmr",
		"crypto",
		"self-hosted",
		"wallet-rpc",
		"webhook",
		"coin-moebius"
	],
	"author": "aquarian-metals",
	"license": "MIT",
	"homepage": "https://github.com/aquarian-metals/coin-moebius#readme",
	"bugs": {
		"url": "https://github.com/aquarian-metals/coin-moebius/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aquarian-metals/coin-moebius.git",
		"directory": "packages/providers/monero"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
		"build": "npm run clean && tsc",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@aquarian-metals/coin-moebius-core": "^1.0.0"
	},
	"devDependencies": {
		"@aquarian-metals/coin-moebius-server": "^1.0.0",
		"typescript": "~5.8.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
