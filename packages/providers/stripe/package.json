{
	"name": "@aquarian-metals/coin-moebius-stripe",
	"version": "0.3.0",
	"description": "Stripe provider for Coin Moebius — browser checkout entry plus a server-only webhook verifier under the ./server subpath.",
	"keywords": [
		"payments",
		"stripe",
		"checkout",
		"webhook",
		"coin-moebius"
	],
	"author": "aquarian-metals",
	"license": "MIT",
	"homepage": "https://github.com/aquarian-metals/coin-moebius#readme",
	"bugs": {
		"url": "https://github.com/aquarian-metals/coin-moebius/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aquarian-metals/coin-moebius.git",
		"directory": "packages/providers/stripe"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
		"build": "npm run clean && tsc",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@aquarian-metals/coin-moebius-core": "^0.3.0",
		"@stripe/stripe-js": "^4.0.0"
	},
	"peerDependencies": {
		"stripe": "^17.4.0"
	},
	"peerDependenciesMeta": {
		"stripe": {
			"optional": true
		}
	},
	"devDependencies": {
		"stripe": "^17.4.0",
		"typescript": "~5.8.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
