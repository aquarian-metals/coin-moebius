{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM"],
		"noEmit": true,
		"allowImportingTsExtensions": false
	},
	"include": [
		"packages/**/src/**/*",
		"packages/**/test/**/*",
		"examples/**/*.ts",
		"scripts/**/*",
		"*.config.*"
	],
	"exclude": ["**/dist/**", "**/node_modules/**"]
}
