{
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"printWidth": 100,
	"tabWidth": 2,
	"useTabs": true,
	"arrowParens": "always",
	"endOfLine": "lf",
	"bracketSpacing": true,
	"overrides": [
		{
			"files": "*.md",
			"options": {
				"useTabs": false,
				"printWidth": 120,
				"proseWrap": "preserve"
			}
		},
		{
			"files": "*.{yml,yaml}",
			"options": {
				"useTabs": false,
				"singleQuote": false
			}
		},
		{
			"files": "*.{json,jsonc}",
			"options": {
				"useTabs": true
			}
		}
	]
}
