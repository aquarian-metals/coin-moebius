{
	"name": "coin-moebius",
	"private": true,
	"workspaces": [
		"packages/core",
		"packages/coin-moebius",
		"packages/server",
		"packages/providers/template",
		"packages/providers/stripe",
		"packages/providers/monero-cryptomus",
		"examples/static-site-demo"
	],
	"scripts": {
		"build": "npm run build --if-present -w @aquarian-metals/coin-moebius-core -w @aquarian-metals/coin-moebius-server -w @aquarian-metals/coin-moebius-stripe -w @aquarian-metals/coin-moebius-monero-cryptomus -w @aquarian-metals/coin-moebius-provider-template -w @aquarian-metals/coin-moebius -w coin-moebius-demo",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"typescript": "~5.8.0",
		"vitest": "^2.1.9"
	}
}
