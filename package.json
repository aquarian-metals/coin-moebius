{
	"name": "coin-moebius",
	"private": true,
	"workspaces": [
		"packages/core",
		"packages/server",
		"packages/providers/stripe",
		"packages/providers/cryptomus",
		"packages/providers/nowpayments",
		"packages/providers/dodopayments",
		"packages/providers/coinbase-business",
		"packages/providers/paypal",
		"packages/providers/authorizenet",
		"packages/providers/square",
		"packages/providers/monero",
		"packages/providers/manual",
		"packages/providers/template",
		"packages/coin-moebius",
		"examples/static-site-demo"
	],
	"scripts": {
		"build": "npm run build --if-present --workspaces",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc -p tsconfig.eslint.json --noEmit",
		"attw": "node scripts/check-types.mjs",
		"size": "size-limit",
		"docs": "typedoc",
		"bump": "node scripts/bump-version.mjs",
		"release": "node scripts/release.mjs",
		"check:sync": "node scripts/check-sync.mjs",
		"verify": "npm run format:check && npm run build && npm run lint && npm run typecheck && npm run test:coverage && npm run attw && npm run size",
		"prepare": "husky"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.16.4",
		"@eslint/js": "^9.13.0",
		"@size-limit/preset-small-lib": "^11.1.6",
		"@types/node": "^25.8.0",
		"@vitest/coverage-v8": "^4.1.0",
		"eslint": "^9.13.0",
		"globals": "^15.11.0",
		"happy-dom": "^20.8.9",
		"husky": "^9.1.6",
		"lint-staged": "^15.2.10",
		"prettier": "^3.3.3",
		"size-limit": "^11.1.6",
		"typedoc": "^0.28.0",
		"typescript": "~5.8.0",
		"typescript-eslint": "^8.12.0",
		"vitest": "^4.1.0"
	},
	"overridesNote": "fflate is pinned to 0.8.2 because @arethetypeswrong/cli@0.16.4 reads fflate's streaming Gunzip via a callback that keeps only the last chunk; fflate 0.8.3's multi-chunk output makes attw read an empty tarball and crash with `reading 'filename'`. Remove this override once attw is upgraded past the fflate streaming fix.",
	"overrides": {
		"fflate": "0.8.2"
	},
	"lint-staged": {
		"*.{ts,tsx,js,mjs,cjs}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{json,md,yml,yaml,html}": [
			"prettier --write"
		]
	}
}
